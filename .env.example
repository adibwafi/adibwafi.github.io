NEXT_PUBLIC_GA_ID=G-XXXXXX
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-gsc-verification-code

# Sentry Error Tracking (Optional — https://sentry.io free tier)
# 1. Sign up at sentry.io → New Project → Next.js → copy DSN below
# 2. Only activates in NODE_ENV=production
NEXT_PUBLIC_SENTRY_DSN=

# Optional: Enable source map upload for better error stack traces
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
